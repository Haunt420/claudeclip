<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardBackgroundColor="#1A1A2E"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <ImageView android:id="@+id/ivDragHandle"
            android:layout_width="24dp" android:layout_height="24dp"
            android:src="@drawable/ic_drag_handle"
            android:layout_marginEnd="12dp" />

        <ImageView android:id="@+id/ivActionIcon"
            android:layout_width="32dp" android:layout_height="32dp"
            android:layout_marginEnd="12dp" />

        <TextView android:id="@+id/tvActionTitle"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#EEFFFFFF"
            android:textSize="14sp" />

        <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchEnabled"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
